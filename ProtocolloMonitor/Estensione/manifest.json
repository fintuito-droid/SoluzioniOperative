{
  "manifest_version": 3,
  "name": "Protocollo VVF Monitor",
  "version": "1.0",
  "description": "Monitora le schede del protocollo, mostra Grisù e avvia lo scraping automatico",
  "permissions": [
    "tabs",
    "webNavigation",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "https://protocollo.dipvvf.it/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "grisu_assistente_menu_operativo.html",
        "grisu_piccolo.png",
        "grisu_fly.png"
      ],
      "matches": [
        "https://protocollo.dipvvf.it/*"
      ]
    }
  ],
  "action": {
    "default_title": "Protocollo Monitor"
  }
}