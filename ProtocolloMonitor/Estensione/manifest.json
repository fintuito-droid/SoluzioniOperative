{
  "manifest_version": 3,
  "name": "Protocollo VVF Monitor",
  "version": "2.0",
  "description": "Monitora le schede del protocollo e mostra Grisù v2",
  "permissions": [
    "tabs",
    "webNavigation",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "https://protocollo.dipvvf.it/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://protocollo.dipvvf.it/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "grisu-v2/dist/index.html",
        "grisu-v2/dist/assets/*",
        "grisu-v2/dist/img/*"
      ],
      "matches": [
        "https://protocollo.dipvvf.it/*"
      ]
    }
  ],
  "action": {
    "default_title": "Protocollo Monitor"
  }
}